{
  "name": "haraka-plugin-p0f",
  "version": "1.0.12",
  "description": "Haraka plugin that adds TCP fingerprinting",
  "files": [
    "config",
    "contrib",
    "CHANGELOG.md"
  ],
  "main": "index.js",
  "scripts": {
    "format": "npm run prettier:fix && npm run lint:fix",
    "lint": "npx eslint *.js test",
    "lint:fix": "npx eslint --fix *.js test",
    "prettier": "npx prettier . --check",
    "prettier:fix": "npx prettier . --write --log-level=warn",
    "test": "npx mocha",
    "test:coverage": "HARAKA_COVERAGE=1 npx c8 npm test",
    "versions": "npx dependency-version-checker check",
    "versions:fix": "npx dependency-version-checker update"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/haraka/haraka-plugin-p0f.git"
  },
  "keywords": [
    "haraka",
    "plugin",
    "p0f"
  ],
  "author": "Haraka Team <haraka.mail@gmail.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/haraka/haraka-plugin-p0f/issues"
  },
  "homepage": "https://github.com/haraka/haraka-plugin-p0f#readme",
  "devDependencies": {
    "@haraka/eslint-config": "^2.0.3",
    "haraka-test-fixtures": "^1.3.10",
  },
  "dependencies": {
    "ipaddr.js": "^2.2.0"
  },
  "engines": {
    "node": ">=20"
  },
  "c8": {
    "reporter": [
      "text",
      "text-summary",
      "html"
    ]
  },
  "prettier": {
    "printWidth": 120,
    "singleQuote": true,
    "semi": false
  }
}
